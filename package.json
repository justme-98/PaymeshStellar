{
  "name": "paymeshshellar",
  "version": "0.1.0",
  "private": true,
  "description": "PaymeshStellar - Next.js frontend, Express.js backend, and Stellar Soroban smart contract",
  "scripts": {
    "prepare": "husky install",
    "build:frontend": "pnpm --filter frontend build",
    "lint:frontend": "pnpm --filter frontend lint",
    "typecheck:frontend": "pnpm --filter frontend type-check",
    "build:backend": "pnpm --filter backend build",
    "lint:backend": "pnpm --filter backend lint",
    "typecheck:backend": "pnpm --filter backend type-check",
    "build:contract": "cd contract && cargo build",
    "clippy:contract": "cd contract && cargo clippy --all --all-targets -- -D warnings",
    "test:contract": "cd contract && cargo test",
    "fmt:contract": "cd contract && cargo fmt --all -- --check",
    "pre-push:check": "pnpm typecheck:frontend && pnpm lint:frontend && pnpm build:frontend && pnpm typecheck:backend && pnpm lint:backend && pnpm build:backend && pnpm fmt:contract && pnpm clippy:contract && pnpm test:contract && pnpm build:contract"
  },
  "devDependencies": {
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
